# 로컬에서는 없어도 됩니다. 없으면 .data/app-state.json 파일 저장소를 사용합니다.
# Vercel Marketplace의 Neon 연결 문자열을 넣으면 서버 API가 Postgres를 사용합니다.
POSTGRES_URL=

# 관리자 화면 비밀번호입니다. 배포 전 반드시 바꾸세요.
ADMIN_PASSWORD=1234

# 관리자 로그인 쿠키 서명용 값입니다. 배포 전 길고 랜덤한 문자열로 바꾸세요.
ADMIN_SESSION_SECRET=change-this-before-deploy

# 학생 로그인 쿠키 서명용 값입니다. 배포 전 길고 랜덤한 문자열로 바꾸세요.
STUDENT_SESSION_SECRET=change-this-before-deploy-too

# 강사용 라이선스 키 생성/검증용 값입니다. 배포 전 길고 랜덤한 문자열로 바꾸세요.
HANJA_LICENSE_SECRET=change-this-license-secret
